# Copy to .env.local and fill in.
# For local dev with `supabase start`, the local CLI prints these values.

VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=

# Production (set in your hosting platform):
# VITE_SUPABASE_URL=https://<project-ref>.supabase.co
# VITE_SUPABASE_ANON_KEY=<from supabase dashboard>

# LLM (at least one required — router prefers Anthropic, falls back to OpenAI).
# Dev only: Vite bundles VITE_* into the client. For production, the router
# should call a Supabase Edge Function proxy that holds the key server-side.
VITE_ANTHROPIC_API_KEY=
VITE_ANTHROPIC_DIRECT=1
VITE_OPENAI_API_KEY=
