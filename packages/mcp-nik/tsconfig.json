{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "allowImportingTsExtensions": false,
    "verbatimModuleSyntax": true,
    "types": ["node"]
  },
  "include": [
    "src/**/*",
    "../../web/src/contracts/**/*",
    "../../web/src/types/**/*",
    "../../web/src/lib/operations.ts",
    "../../web/src/lib/commands.ts"
  ]
}
